UNWIND [{srcId: "15.1", srcYear: 2029, targetId: "6.2", targetYear: 2029}, {srcId: "15.1", srcYear: 2029, targetId: "1.2", targetYear: 2029}, {srcId: "15.2", srcYear: 2025, targetId: "1.2", targetYear: 2025}, {srcId: "15.2", srcYear: 2025, targetId: "4.4", targetYear: 2025}, {srcId: "15.2", srcYear: 2025, targetId: "6.2.1", targetYear: 2025}, {srcId: "15.2", srcYear: 2026, targetId: "6.2.1", targetYear: 2026}, {srcId: "15.2", srcYear: 2026, targetId: "4.4", targetYear: 2026}, {srcId: "15.2", srcYear: 2026, targetId: "1.2", targetYear: 2026}, {srcId: "15.2", srcYear: 2027, targetId: "6.2.1", targetYear: 2027}, {srcId: "15.2", srcYear: 2027, targetId: "4.4", targetYear: 2027}, {srcId: "15.2", srcYear: 2027, targetId: "1.2", targetYear: 2027}, {srcId: "15.2", srcYear: 2028, targetId: "6.2.1", targetYear: 2028}, {srcId: "15.2", srcYear: 2028, targetId: "4.4", targetYear: 2028}, {srcId: "15.2", srcYear: 2028, targetId: "1.2", targetYear: 2028}, {srcId: "15.2", srcYear: 2029, targetId: "6.2.1", targetYear: 2029}, {srcId: "15.2", srcYear: 2029, targetId: "6.2", targetYear: 2029}, {srcId: "15.2", srcYear: 2029, targetId: "1.2", targetYear: 2029}] AS r MATCH (sp:SectorPerformance {id: r.srcId, year: r.srcYear}) MATCH (t:EntityCapability {id: r.targetId, year: r.targetYear}) MERGE (sp)-[:SETS_TARGETS]->(t) RETURN count(*) AS created